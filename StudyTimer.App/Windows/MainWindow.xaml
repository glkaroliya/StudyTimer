<Window x:Class="StudyTimer.App.Windows.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="StudyTimer" Width="1000" Height="660"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style x:Key="NavBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#3D4F63"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="180"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <StackPanel Grid.Column="0" Background="#2D3A4A">
            <TextBlock x:Name="TxtAppTitle" Text="StudyTimer" Foreground="White" FontSize="18" FontWeight="Bold"
                       Margin="16,20,16,4"/>
            <TextBlock x:Name="TxtUserInfo" Text="" Foreground="#AAB8C8" FontSize="11" Margin="16,0,16,20" TextWrapping="Wrap"/>

            <Button x:Name="BtnDashboard" Content="📊 Dashboard" Style="{StaticResource NavBtn}" Click="NavBtn_Click" Tag="Dashboard"/>
            <Button x:Name="BtnTimetable" Content="📅 Timetable" Style="{StaticResource NavBtn}" Click="NavBtn_Click" Tag="Timetable"/>
            <Button x:Name="BtnTimer" Content="⏱ Timer" Style="{StaticResource NavBtn}" Click="NavBtn_Click" Tag="Timer"/>
            <Button x:Name="BtnStudents" Content="👥 Students" Style="{StaticResource NavBtn}" Click="NavBtn_Click" Tag="Students"/>
            <Button x:Name="BtnSubjects" Content="📚 Subjects" Style="{StaticResource NavBtn}" Click="NavBtn_Click" Tag="Subjects"/>
            <Button x:Name="BtnProgress" Content="📈 Progress" Style="{StaticResource NavBtn}" Click="NavBtn_Click" Tag="Progress"/>
            <Button x:Name="BtnSettings" Content="⚙ Settings" Style="{StaticResource NavBtn}" Click="NavBtn_Click" Tag="Settings"/>

            <Button Content="🚪 Sign Out" Style="{StaticResource NavBtn}" Click="BtnSignOut_Click"
                    Margin="0,40,0,0" Foreground="#FF8080"/>
        </StackPanel>

        <!-- Content Frame -->
        <Frame x:Name="MainFrame" Grid.Column="1" NavigationUIVisibility="Hidden"/>
    </Grid>
</Window>
