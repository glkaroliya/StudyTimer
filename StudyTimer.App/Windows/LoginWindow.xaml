<Window x:Class="StudyTimer.App.Windows.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="StudyTimer — Sign In"
        Width="400" Height="320"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen">
    <StackPanel Margin="40,30,40,30" VerticalAlignment="Center">
        <TextBlock Text="StudyTimer" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,20"/>

        <TextBlock Text="Username" Margin="0,0,0,4"/>
        <TextBox x:Name="TxtUsername" Height="30" Padding="4"/>

        <TextBlock Text="Password" Margin="0,10,0,4"/>
        <PasswordBox x:Name="PwdPassword" Height="30" Padding="4"/>

        <TextBlock x:Name="TxtError" Foreground="Red" TextWrapping="Wrap" Margin="0,8,0,0" Visibility="Collapsed"/>

        <Button Content="Sign In" Height="34" Margin="0,16,0,0" Click="BtnSignIn_Click" Background="#2D3A4A" Foreground="White" FontWeight="Bold"/>

        <Button x:Name="BtnRegisterLink" Content="First run? Register Admin" Margin="0,8,0,0" Background="Transparent"
                BorderBrush="Transparent" Foreground="#2D3A4A"
                Click="BtnRegisterLink_Click" Cursor="Hand" HorizontalAlignment="Center"/>

        <StackPanel x:Name="PanelRegister" Visibility="Collapsed" Margin="0,10,0,0">
            <TextBlock Text="Register Admin" FontWeight="Bold" Margin="0,0,0,6"/>
            <TextBlock Text="New Username" Margin="0,0,0,4"/>
            <TextBox x:Name="TxtRegUsername" Height="30" Padding="4"/>
            <TextBlock Text="New Password" Margin="0,6,0,4"/>
            <PasswordBox x:Name="PwdRegPassword" Height="30" Padding="4"/>
            <Button Content="Register" Height="30" Margin="0,8,0,0" Click="BtnRegister_Click" Background="#2D3A4A" Foreground="White"/>
        </StackPanel>
    </StackPanel>
</Window>
