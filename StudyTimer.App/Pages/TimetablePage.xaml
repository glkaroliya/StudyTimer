<Page x:Class="StudyTimer.App.Pages.TimetablePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Timetable">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Timetable" FontSize="22" FontWeight="Bold" Margin="0,0,0,12"/>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,12">
            <TextBlock Text="Student:" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <ComboBox x:Name="CboStudents" Width="160" DisplayMemberPath="Name" SelectionChanged="Filter_Changed"/>
            <TextBlock Text="Date:" VerticalAlignment="Center" Margin="16,0,8,0"/>
            <DatePicker x:Name="DpDate" SelectedDateChanged="Filter_Changed"/>
        </StackPanel>

        <DataGrid Grid.Row="2" x:Name="GridSlots" AutoGenerateColumns="False" IsReadOnly="True"
                  CanUserAddRows="False" SelectionMode="Single" Margin="0,0,0,8">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="40"/>
                <DataGridTextColumn Header="Subject" Binding="{Binding SubjectName}" Width="100"/>
                <DataGridTextColumn Header="Date" Binding="{Binding Date, StringFormat=yyyy-MM-dd}" Width="90"/>
                <DataGridTextColumn Header="Start" Binding="{Binding StartTime, StringFormat=HH\\:mm}" Width="60"/>
                <DataGridTextColumn Header="Duration (min)" Binding="{Binding DurationMinutes}" Width="100"/>
                <DataGridTextColumn Header="Activity" Binding="{Binding ActivityDescription}" Width="*"/>
                <DataGridTextColumn Header="Done" Binding="{Binding Completed}" Width="50"/>
                <DataGridTextColumn Header="Rescheduled" Binding="{Binding IsRescheduled}" Width="80"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="3" Orientation="Horizontal">
            <Button Content="Add" Width="70" Margin="0,0,8,0" Click="BtnAdd_Click"/>
            <Button Content="Edit" Width="70" Margin="0,0,8,0" Click="BtnEdit_Click"/>
            <Button Content="Delete" Width="70" Margin="0,0,8,0" Click="BtnDelete_Click"/>
            <Button Content="Mark Complete" Width="110" Margin="0,0,8,0" Click="BtnComplete_Click"/>
            <Button Content="Reschedule" Width="100" Click="BtnReschedule_Click"/>
        </StackPanel>

        <!-- Edit form overlay -->
        <Border Grid.Row="0" Grid.RowSpan="4" x:Name="PanelForm" Visibility="Collapsed"
                Background="#F0F4F8" CornerRadius="8" Padding="20" HorizontalAlignment="Right" VerticalAlignment="Top"
                Width="320">
            <StackPanel>
                <TextBlock x:Name="TxtFormTitle" Text="Add Slot" FontSize="16" FontWeight="Bold" Margin="0,0,0,12"/>
                <TextBlock Text="Subject"/>
                <ComboBox x:Name="CboSubjects" DisplayMemberPath="Name" Margin="0,0,0,8" Height="28"/>
                <TextBlock Text="Date"/>
                <DatePicker x:Name="DpFormDate" Margin="0,0,0,8"/>
                <TextBlock Text="Start Time (HH:mm)"/>
                <TextBox x:Name="TxtStartTime" Margin="0,0,0,8" Height="28" Padding="4"/>
                <TextBlock Text="Duration (minutes)"/>
                <TextBox x:Name="TxtDuration" Margin="0,0,0,8" Height="28" Padding="4"/>
                <TextBlock Text="Activity Description"/>
                <TextBox x:Name="TxtActivity" Margin="0,0,0,12" Height="60" TextWrapping="Wrap" AcceptsReturn="True" Padding="4"/>
                <StackPanel Orientation="Horizontal">
                    <Button Content="Save" Width="70" Margin="0,0,8,0" Click="BtnSave_Click" Background="#2D3A4A" Foreground="White"/>
                    <Button Content="Cancel" Width="70" Click="BtnCancel_Click"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Reschedule form overlay -->
        <Border Grid.Row="0" Grid.RowSpan="4" x:Name="PanelReschedule" Visibility="Collapsed"
                Background="#F0F4F8" CornerRadius="8" Padding="20" HorizontalAlignment="Right" VerticalAlignment="Top"
                Width="300">
            <StackPanel>
                <TextBlock Text="Reschedule Slot" FontSize="16" FontWeight="Bold" Margin="0,0,0,12"/>
                <TextBlock Text="New Date"/>
                <DatePicker x:Name="DpRescheduleDate" Margin="0,0,0,8"/>
                <TextBlock Text="New Start Time (HH:mm)"/>
                <TextBox x:Name="TxtRescheduleTime" Margin="0,0,0,12" Height="28" Padding="4"/>
                <StackPanel Orientation="Horizontal">
                    <Button Content="Reschedule" Width="90" Margin="0,0,8,0" Click="BtnDoReschedule_Click" Background="#2D3A4A" Foreground="White"/>
                    <Button Content="Cancel" Width="70" Click="BtnCancelReschedule_Click"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Page>
