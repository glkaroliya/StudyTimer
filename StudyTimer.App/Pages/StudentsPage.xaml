<Page x:Class="StudyTimer.App.Pages.StudentsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Students">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Students" FontSize="22" FontWeight="Bold" Margin="0,0,0,12"/>

        <DataGrid Grid.Row="1" x:Name="GridStudents" AutoGenerateColumns="False" IsReadOnly="True"
                  CanUserAddRows="False" SelectionMode="Single">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*"/>
                <DataGridTextColumn Header="Grade" Binding="{Binding Grade}" Width="60"/>
                <DataGridTextColumn Header="Active" Binding="{Binding IsActive}" Width="60"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,8,0,8">
            <Button Content="Add" Width="70" Margin="0,0,8,0" Click="BtnAdd_Click"/>
            <Button Content="Edit" Width="70" Margin="0,0,8,0" Click="BtnEdit_Click"/>
            <Button Content="Delete" Width="70" Click="BtnDelete_Click"/>
        </StackPanel>

        <Border Grid.Row="3" x:Name="PanelForm" Visibility="Collapsed" Background="#F0F4F8" CornerRadius="8" Padding="16">
            <StackPanel>
                <TextBlock x:Name="TxtFormTitle" Text="Add Student" FontSize="14" FontWeight="Bold" Margin="0,0,0,8"/>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBlock Text="Name:" Width="60" VerticalAlignment="Center"/>
                    <TextBox x:Name="TxtName" Width="180" Height="28" Padding="4"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBlock Text="Grade:" Width="60" VerticalAlignment="Center"/>
                    <TextBox x:Name="TxtGrade" Width="60" Height="28" Padding="4"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBlock Text="Active:" Width="60" VerticalAlignment="Center"/>
                    <CheckBox x:Name="ChkActive" IsChecked="True" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <Button Content="Save" Width="70" Margin="0,0,8,0" Click="BtnSave_Click" Background="#2D3A4A" Foreground="White"/>
                    <Button Content="Cancel" Width="70" Click="BtnCancel_Click"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Page>
